# Google Sheets
SPREADSHEET_ID=your_sheet_id_here
SHEET_NAME=Form Responses 1
GOOGLE_SERVICE_ACCOUNT_KEY=service_account.json

# GitHub
GITHUB_REPO_URL=https://github.com/roff-dev/money-machine.git

# Netlify
NETLIFY_AUTH_TOKEN=
NETLIFY_TEAM_SLUG=
# Leave NETLIFY_SITE_ID blank to create a new site per client
NETLIFY_SITE_ID=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# Branding
BASE_DOMAIN=yourbrand.co.uk

# Google Sheet columns for deploy results (add these columns manually)
# Default: T = Site URL, U = Deployed At
DEPLOYED_URL_COL_LETTER=T
DEPLOYED_AT_COL_LETTER=U
